<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="item"
            type="com.iwelogic.presentation.models.NewsPresentation" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/default_size"
        android:layout_marginTop="@dimen/half_default_size"
        android:layout_marginEnd="@dimen/default_size"
        android:layout_marginBottom="@dimen/half_default_size"
        app:cardCornerRadius="@dimen/half_default_size"
        app:cardElevation="@dimen/quarter_default_size">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/image"
                image="@{item.image}"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:contentDescription="@string/news_image"
                app:layout_constraintDimensionRatio="34:19"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/title"
                style="@style/Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/default_size"
                android:layout_marginTop="@dimen/half_default_size"
                android:layout_marginEnd="@dimen/default_size"
                android:layout_marginBottom="@dimen/default_size"
                android:text="@{item.title}"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/image" />


        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.cardview.widget.CardView>

</layout>

