<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="@dimen/double_default_size"
        android:background="@drawable/background_dialog"
        android:orientation="vertical"
        android:padding="@dimen/default_size"
        tools:ignore="UselessParent">

        <TextView
            android:id="@+id/message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/open_sans_bold"
            android:letterSpacing="0.04"
            android:paddingStart="@dimen/default_size"
            android:paddingTop="@dimen/default_size"
            android:paddingEnd="@dimen/default_size"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/default_size"
            android:gravity="end">

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_gravity="end"
                android:background="?attr/actionBarItemBackground"
                android:fontFamily="@font/open_sans_bold"
                android:gravity="center"
                android:minWidth="80dp"
                android:paddingStart="@dimen/default_size"
                android:paddingEnd="@dimen/default_size"
                android:text="@string/cancel"
                android:textColor="@color/button"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btnOk"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_gravity="end"
                android:background="?attr/actionBarItemBackground"
                android:fontFamily="@font/open_sans_bold"
                android:gravity="center"
                android:minWidth="80dp"
                android:paddingStart="@dimen/default_size"
                android:paddingEnd="@dimen/default_size"
                android:text="@string/ok"
                android:textColor="@color/button"
                android:textSize="15sp" />

        </LinearLayout>
    </LinearLayout>
</FrameLayout>