<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.iwelogic.portfolio.ui.login.LoginFragment"
        android:label="LoginFragment" />
    <fragment
        android:id="@+id/mainFragment"
        android:name="com.iwelogic.portfolio.ui.main_fragment.MainFragment"
        android:label="MainFragment" />
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.iwelogic.portfolio.ui.register.RegisterFragment"
        android:label="RegisterFragment" /><action android:id="@+id/action_global_registerFragment" app:destination="@id/registerFragment"/>
    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.iwelogic.portfolio.ui.forgot_password.ForgotPasswordFragment"
        android:label="ForgotPasswordFragment" >
        <argument
            android:name="email"
            app:argType="string"
            app:nullable="true" />
    </fragment>
    <action android:id="@+id/action_global_forgotPasswordFragment" app:destination="@id/forgotPasswordFragment" />
</navigation>