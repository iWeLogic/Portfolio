<resources>

    <style name="EditField">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">@dimen/default_size</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:paddingEnd">@dimen/default_size</item>
        <item name="android:background">@drawable/background_edit_field</item>
        <item name="android:fontFamily">@font/open_sans_regular</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="Button">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textColor">@color/buttonTextColor</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingStart">@dimen/double_default_size</item>
        <item name="android:paddingEnd">@dimen/double_default_size</item>
        <item name="android:minWidth">182dp</item>
        <item name="android:fontFamily">@font/open_sans_regular</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:background">@drawable/background_button</item>
    </style>

    <style name="Header">
        <item name="android:textColor">@color/buttonPressedColor</item>
        <item name="android:textSize">17sp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/open_sans_bold</item>
    </style>


    <style name="CustomAlertDialog" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@color/transparent</item>
    </style>

    <style name="BottomNavigationView" parent="@style/TextAppearance.AppCompat.Caption">
        <item name="android:textSize">10sp</item>
    </style>

</resources>